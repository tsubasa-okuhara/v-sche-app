# Streamlit設定例
# このファイルを .streamlit/config.toml にコピーして使用

[client]
showErrorDetails = true
logger.level = "info"

[logger]
level = "info"

[theme]
base = "light"
primaryColor = "#1f77b4"
backgroundColor = "#ffffff"
secondaryBackgroundColor = "#f0f2f6"
textColor = "#262730"
font = "sans serif"

[server]
maxUploadSize = 200
enableXsrfProtection = true
